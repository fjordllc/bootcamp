{
  "scripts": {
    "lint": "run-p lint:*",
    "lint:eslint": "eslint 'app/javascript/**/*.js' --max-warnings=0",
    "lint:openapi": "bundle exec ruby bin/lint-openapi && npm run build:openapi-docs -- --check",
    "lint:prettier": "prettier 'app/javascript/**/*.js' --check",
    "lint:stylelint": "stylelint 'app/assets/stylesheets/**/*.css'",
    "build:openapi-docs": "ruby bin/build-openapi-docs"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "neostandard": "^0.13.0",
    "npm-run-all": "^4.1.5",
    "playwright": "1.60.0",
    "prettier": "^3.8.4",
    "prettier-config-standard": "^7.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "swagger-ui-dist": "^5.32.6"
  },
  "engines": {
    "node": ">=20.9.0 <23"
  },
  "license": "MIT"
}
