{
  "extends": [
    "eslint:recommended",
    "standard",
    "prettier"
  ],
  "env": {
    "browser": true,
    "jquery": true,
    "node": true
  },
  "globals": {
    "Worker": true,
    "IntersectionObserver": true
  },
  "root": true,
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "args": "all",
        "argsIgnorePattern": "^_"
      }
    ]
  }
}
