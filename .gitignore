# See http://help.github.com/ignore-files/ for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile ~/.gitignore_global

# Ignore bundler config
/.bundle

# Ignore the default SQLite database.
/db/*.sqlite3

# Ignore all logfiles and tempfiles.
/log/*
/tmp
!/tmp/
/tmp/*
!/tmp/cache/
/tmp/cache/*
!/tmp/cache/.keep
!/log/.keep

vendor/bundle/*
!vendor/bundle/
!vendor/bundle/.keep

/node_modules/*
!/node_modules/
!/node_modules/.keep
/yarn-error.log

.byebug_history
/public/assets
/public/packs/*
/public/packs-test/*
!/public/packs/
!/public/packs/.keep
!/public/packs-test/
!/public/packs-test/.keep
/app/assets/builds/*
!/app/assets/builds/.gitkeep

/public/system
yarn-debug.log*
.yarn-integrity

/*.pdf

storage/

# Ignore master key for decrypting credentials and more.
/config/master.key

.envrc
.env.local
/test/reports

/yarn-error.log
yarn-debug.log*
.yarn-integrity

.claude
