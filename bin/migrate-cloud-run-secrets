def run(*command, stdin_data: nil)
  stdout, stderr, status = Open3.capture3(*command, stdin_data:)
  return stdout if status.success?

  warn stderr
  abort "Command failed: #{command.shelljoin}"
end

def trigger_substitutions(trigger)
  json = run('gcloud', 'builds', 'triggers', 'describe', trigger, "--project=#{PROJECT}", '--format=json')
  substitutions = JSON.parse(json).fetch('substitutions')
  extra_env = substitutions.fetch('_ENVS', '').split(',').filter_map do |pair|
    key, value = pair.split('=', 2)
    [key, value] if key && value
  end.to_h

  substitutions.transform_keys { |key| key.delete_prefix('_') }.merge(extra_env)
end

def secret_exists?(name)
  _stdout, _stderr, status = Open3.capture3('gcloud', 'secrets', 'describe', name, "--project=#{PROJECT}", '--format=value(name)')
  status.success?
end

def create_secret(name, value)
  run('gcloud', 'secrets', 'create', name, "--project=#{PROJECT}", '--replication-policy=automatic', '--data-file=-', stdin_data: value)
end

ENVIRONMENTS.each do |environment, config|
  substitutions = trigger_substitutions(config.fetch(:trigger))

  config.fetch(:secrets).each do |env_name, secret_suffix|
    value = substitutions[env_name]
    if value.nil? || value.empty? # rubocop:disable Rails/Blank
      puts "skip bootcamp-#{environment}-#{secret_suffix}: #{env_name} is not set"
      next
    end

    secret_name = "bootcamp-#{environment}-#{secret_suffix}"
    if secret_exists?(secret_name)
      puts "exists #{secret_name}"
    elsif DRY_RUN
      puts "would create #{secret_name}"
    else
      create_secret(secret_name, value)
      puts "created #{secret_name}"
    end
  end
end
