#!/usr/bin/env ruby
require "fileutils"
require "socket"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def find_free_port(range = 3001..3999)
  range.find do |port|
    begin
      server = TCPServer.new("127.0.0.1", port)
      server.close
      true
    rescue Errno::EADDRINUSE
      false
    end
  end
end

def setup_worktree_env
  db_suffix = ENV["CLAUDE_WORKTREE_DB_SUFFIX"].to_s.strip
  return if db_suffix.empty?

  unless db_suffix.match?(/\A[a-zA-Z0-9_]+\z/)
    abort "Error: CLAUDE_WORKTREE_DB_SUFFIX must match [a-zA-Z0-9_]+"
  end

  ENV["BRANCH_DB_SUFFIX"] = "_#{db_suffix}"

  port = find_free_port
  abort "Error: No free port available in 3001..3999" unless port

  worktree_name = ENV["CLAUDE_WORKTREE_NAME"].to_s.gsub(/[\r\n]/, " ")
  env_local_path = File.join(APP_ROOT, ".env.local")

  File.write(env_local_path, <<~ENV)
    # Generated by bin/setup for worktree: #{worktree_name}
    PORT=#{port}
    BRANCH_DB_SUFFIX=_#{db_suffix}
  ENV

  puts "== Worktree mode detected =="
  puts "  Name: #{worktree_name}"
  puts "  DB suffix: _#{db_suffix}"
  puts "  Port: #{port}"
  puts "  Generated: .env.local"
  puts ""
end

FileUtils.chdir APP_ROOT do
  setup_worktree_env
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  if File.exist?("package.json")
    puts "\n== Installing JavaScript dependencies =="
    system!("npm install")
  end

  # puts "\n== Copying sample files =="
  # unless File.exist?("config/database.yml")
  #   FileUtils.cp "config/database.yml.sample", "config/database.yml"
  # end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
