#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system_quiet(*args)
  system(*args, out: File::NULL, err: File::NULL)
end

FileUtils.chdir APP_ROOT do
  db_suffix = ENV["CLAUDE_WORKTREE_DB_SUFFIX"]

  if db_suffix
    puts "== Worktree teardown =="
    puts "  Name: #{ENV["CLAUDE_WORKTREE_NAME"]}"
    puts "  DB suffix: _#{db_suffix}"

    ENV["BRANCH_DB_SUFFIX"] = "_#{db_suffix}"

    puts "\n== Dropping databases =="
    if system_quiet("bin/rails", "db:drop")
      puts "  Done (databases dropped)"
    else
      puts "  Done (databases did not exist or already dropped)"
    end

    env_local_path = File.join(APP_ROOT, ".env.local")
    if File.exist?(env_local_path)
      FileUtils.rm(env_local_path)
      puts "\n== Removed .env.local =="
    end
  else
    puts "Not a worktree session, nothing to teardown."
  end
end
