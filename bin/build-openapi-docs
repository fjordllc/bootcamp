#!/usr/bin/env node

const fs = require('fs')
const os = require('os')
const path = require('path')

const root = path.resolve(__dirname, '..')
const swaggerUiDist = path.dirname(require.resolve('swagger-ui-dist/package.json'))
const outputDir = path.join(root, 'public', 'api-docs')
const checkMode = process.argv.includes('--check')

function copyFile(source, destination) {
  if (!fs.existsSync(source)) {
    throw new Error(`Source file does not exist: ${source}`)
  }

  try {
    fs.copyFileSync(source, destination)
  } catch (error) {
    throw new Error(
      `Failed to copy ${source} to ${destination}: ${error.message}`
    )
  }
}

function build(targetDir) {
  fs.rmSync(targetDir, { recursive: true, force: true })
  fs.mkdirSync(targetDir, { recursive: true })

  for (const file of [
    'swagger-ui.css',
    'swagger-ui-bundle.js',
    'swagger-ui-standalone-preset.js'
  ]) {
    copyFile(path.join(swaggerUiDist, file), path.join(targetDir, file))
  }

  copyFile(
    path.join(root, 'docs', 'openapi.yaml'),
    path.join(targetDir, 'openapi.yaml')
  )

  fs.writeFileSync(
    path.join(targetDir, 'index.html'),
    `<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FJORD BOOT CAMP API Docs</title>
  <link rel="stylesheet" href="./swagger-ui.css">
  <style>
    body {
      margin: 0;
      background: #fafafa;
    }
  </style>
</head>
<body>
  <div id="swagger-ui"></div>
  <script src="./swagger-ui-bundle.js"></script>
  <script src="./swagger-ui-standalone-preset.js"></script>
  <script>
    window.addEventListener('load', function () {
      window.ui = SwaggerUIBundle({
        url: './openapi.yaml',
        dom_id: '#swagger-ui',
        deepLinking: true,
        presets: [
          SwaggerUIBundle.presets.apis,
          SwaggerUIStandalonePreset
        ],
        layout: 'StandaloneLayout'
      })
    })
  </script>
</body>
</html>
`,
    'utf8'
  )
}

function listFiles(dir) {
  return fs.readdirSync(dir).sort()
}

function assertSameFile(source, destination) {
  if (!fs.existsSync(destination)) {
    throw new Error(`Generated file is missing: ${destination}`)
  }

  if (!fs.readFileSync(source).equals(fs.readFileSync(destination))) {
    throw new Error(
      `${path.relative(root, destination)} is out of date. Run npm run build:openapi-docs.`
    )
  }
}

try {
  if (checkMode) {
    const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'bootcamp-api-docs-'))

    try {
      build(tempDir)
      const expectedFiles = listFiles(tempDir)
      const actualFiles = fs.existsSync(outputDir) ? listFiles(outputDir) : []

      if (expectedFiles.join('\n') !== actualFiles.join('\n')) {
        throw new Error(
          'public/api-docs file list is out of date. Run npm run build:openapi-docs.'
        )
      }

      for (const file of expectedFiles) {
        assertSameFile(path.join(tempDir, file), path.join(outputDir, file))
      }
    } finally {
      fs.rmSync(tempDir, { recursive: true, force: true })
    }

    console.log(`${path.relative(root, outputDir)} is up to date`)
  } else {
    build(outputDir)
    console.log(`Built ${path.relative(root, outputDir)}`)
  }
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
