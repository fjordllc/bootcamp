#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'pathname'
require 'tmpdir'

ROOT = Pathname.new(__dir__).join('..').expand_path
SWAGGER_UI_DIST = ROOT.join('node_modules/swagger-ui-dist')
OUTPUT_DIR = ROOT.join('public/api-docs')
CHECK_MODE = ARGV.include?('--check')
ASSET_FILES = %w[
  swagger-ui.css
  swagger-ui-bundle.js
  swagger-ui-standalone-preset.js
].freeze

def copy_file(source, destination)
  raise "Source file does not exist: #{source}" unless source.file?

  FileUtils.cp(source, destination)
rescue SystemCallError => e
  raise "Failed to copy #{source} to #{destination}: #{e.message}"
end

def index_html
  <<~HTML
    <!doctype html>
    <html lang="ja">
    <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1">
      <title>FJORD BOOT CAMP API Docs</title>
      <link rel="stylesheet" href="./swagger-ui.css">
      <style>
        body {
          margin: 0;
          background: #fafafa;
        }
      </style>
    </head>
    <body>
      <div id="swagger-ui"></div>
      <script src="./swagger-ui-bundle.js"></script>
      <script src="./swagger-ui-standalone-preset.js"></script>
      <script>
        window.addEventListener('load', function () {
          window.ui = SwaggerUIBundle({
            url: './openapi.yaml',
            dom_id: '#swagger-ui',
            deepLinking: true,
            presets: [
              SwaggerUIBundle.presets.apis,
              SwaggerUIStandalonePreset
            ],
            layout: 'StandaloneLayout'
          })
        })
      </script>
    </body>
    </html>
  HTML
end

def build(target_dir)
  FileUtils.rm_rf(target_dir)
  FileUtils.mkdir_p(target_dir)

  ASSET_FILES.each do |file|
    copy_file(SWAGGER_UI_DIST.join(file), target_dir.join(file))
  end

  copy_file(ROOT.join('docs/openapi.yaml'), target_dir.join('openapi.yaml'))
  target_dir.join('index.html').write(index_html)
end

def list_files(dir)
  dir.children.map { |path| path.basename.to_s }.sort
end

def assert_same_file(source, destination)
  raise "Generated file is missing: #{destination}" unless destination.file?

  return if source.binread == destination.binread

  raise "#{destination.relative_path_from(ROOT)} is out of date. Run npm run build:openapi-docs."
end

if CHECK_MODE
  Dir.mktmpdir('bootcamp-api-docs-') do |dir|
    temp_dir = Pathname.new(dir)
    build(temp_dir)

    expected_files = list_files(temp_dir)
    actual_files = OUTPUT_DIR.directory? ? list_files(OUTPUT_DIR) : []
    unless expected_files == actual_files
      raise 'public/api-docs file list is out of date. Run npm run build:openapi-docs.'
    end

    expected_files.each do |file|
      assert_same_file(temp_dir.join(file), OUTPUT_DIR.join(file))
    end
  end

  puts "#{OUTPUT_DIR.relative_path_from(ROOT)} is up to date"
else
  build(OUTPUT_DIR)
  puts "Built #{OUTPUT_DIR.relative_path_from(ROOT)}"
end
